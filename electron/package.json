{
  "name": "messenger-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.nexora.messenger",
    "productName": "Nexora",
    "directories": {
      "output": "../dist-electron2"
    },
    "files": [
      "main.js"
    ],
    "win": {
      "target": "portable",
      "icon": "../client/public/icon-512.png",
      "signAndEditExecutable": false
    }
  }
}
