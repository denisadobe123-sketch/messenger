{
  "name": "messenger-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.messenger.app",
    "productName": "Messenger",
    "directories": {
      "output": "../dist-electron"
    },
    "files": [
      "main.js",
      "../server/**/*",
      "../client/dist/**/*",
      "!../server/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/node_modules",
        "to": "server/node_modules"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ru_RU"
      ]
    }
  }
}
